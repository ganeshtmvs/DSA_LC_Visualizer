# LLM Provider Selection
# Set LLM_PROVIDER to one of: ollama | groq | openai | anthropic
# If unset, Ollama is tried first, then the first available cloud provider.
LLM_PROVIDER=

# Optional: override the default model for each provider
OLLAMA_MODEL=llama3
GROQ_MODEL=llama-3.1-8b-instant
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# API Keys — only the keys for providers you want to use are required
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
